# dev | prod
SPRING_PROFILES_ACTIVE=

# Postgres DB
DB_URL=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=
REDIS_PORT=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=

# ---- OAuth2 resource server (add when you wire JWT) ----
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://your-idp/realms/bac

# fix timezone issue (for postgres 18 not support Asia/Saigon)
JAVA_TOOL_OPTIONS=-Duser.timezone=UTC